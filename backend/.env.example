# Copie para .env (o .env é local e não vai para o Git).

# Origens liberadas no CORS, separadas por vírgula.
# Em produção: a URL do frontend na Vercel. Sem isso o navegador bloqueia tudo.
# Padrão quando ausente: http://localhost:5173,http://127.0.0.1:5173
# ALLOWED_ORIGINS=https://seu-projeto.vercel.app

# Caminho do TSV do Instituto. O arquivo NÃO está no repositório (dado pessoal), então
# em produção ele é entregue ao host por fora do Git e costuma cair em outro lugar.
# Padrão quando ausente: backend/data/Formulario2_Resumido.tsv
# DATA_PATH=/etc/secrets/Formulario2_Resumido.tsv

# Porta HTTP. A maioria dos hosts injeta esta variável sozinha.
# PORT=8000

# --- ainda NÃO lidas pelo código (valores fixos) ---
# Limite do CSV enviado, em bytes (MAX_UPLOAD_BYTES em routes/uploads.py)
# MAX_UPLOAD_BYTES=10485760
# Salário mínimo usado nas faixas de renda (MINIMUM_WAGE em cleaning.py)
# MINIMUM_WAGE=1412
BLOB_READ_WRITE_TOKEN=""
INSTITUTE_BLOB_PATH=""
