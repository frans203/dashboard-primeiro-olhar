# Copie para .env (o .env é local e não vai para o Git).
#
# URL base da API. Vazio = usa o proxy do Vite (/api → localhost:8000 em dev).
# Preenchido = o navegador fala direto com a API nesta origem (o backend já libera
# http://localhost:5173 no CORS — veja ALLOWED_ORIGINS em backend/main.py).
# Só variáveis com prefixo VITE_ chegam ao código do cliente.
VITE_API_URL=http://localhost:8000
