# Copie para .env (o .env é local e não vai para o Git).
#
# URL base da API. Só variáveis com prefixo VITE_ chegam ao código do cliente, e o
# valor é injetado em BUILD TIME — mudou a URL, refaça o build.
#
#   Vazio      → caminho relativo (/api/...). É o que vale em DOIS casos:
#                - dev, onde o Vite faz proxy de /api para localhost:8000;
#                - produção na Vercel, onde front e API vivem no mesmo domínio e o
#                  vercel.json roteia /api para o serviço backend. Sem CORS.
#   Preenchido → o navegador fala direto com a API nesta origem. Necessário quando a
#                API está em outro domínio (ex.: Render), e aí o backend precisa
#                liberá-la em ALLOWED_ORIGINS.
VITE_API_URL=http://localhost:8000
