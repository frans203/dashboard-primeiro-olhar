# Dados pessoais — não versionar (nomes, endereços e saúde de crianças)
backend/data/*.tsv
backend/data/*.csv
backend/data/*.xlsx

# Variáveis de ambiente: o .env é de cada máquina; o .env.example é versionado
# (é ele que documenta as chaves), por isso a exceção logo abaixo.
.env
.env.*
!.env.example

# Python
.venv/
__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/

# Node
node_modules/
dist/
dist-ssr/
*.local
.vite/
*.tsbuildinfo

# Editores / SO
.DS_Store
Thumbs.db
.idea/
.vscode/

# Worktrees e estado local do Claude Code — nunca versionar
.claude/worktrees/
.claude/settings.local.json
